# ──────────────────────────────────────────────────────────────
# Root .gitignore — covers both frontend (Next.js) and backend (Django)
# ──────────────────────────────────────────────────────────────

# ── Environment variables ──────────────────────────────────────
.env
.env.*
!.env.example
!**/.env.example

# ── OS / Editor ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Tooling / Planning artifacts ───────────────────────────────
.claude/
.mcp.json
# Original-setup planning docs were archived to docs/archive/ in the
# dev-experience-hardening pass; they are committed there for historical
# reference. New transient planning files at the repo ROOT continue to
# be ignored if a contributor drops them.
/findings.md
/progress.md
/task_plan.md
/*.resolved

# ── Secrets: never commit private keys ─────────────────────────
backend/keys/

# ── Git worktrees (isolated feature branches) ──────────────────
.worktrees/

# ── Transient agent / tooling artifacts (not source) ───────────
.playwright-mcp/
.superpowers/
scraper.rar
scraper/.geocode_cache.json

# ─────────────────────────────────────────────────────────────
# Frontend — Next.js
# ─────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.vercel/
frontend/.turbo/
frontend/coverage/
frontend/dist/
# Python coverage (pytest-cov) artefacts — generated during CI + local runs.
.coverage
.coverage.*
htmlcov/
backend/.coverage
backend/.coverage.*
backend/htmlcov/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ─────────────────────────────────────────────────────────────
# Backend — Python / Django
# ─────────────────────────────────────────────────────────────
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd

# Agents — Python
agents/**/__pycache__/
agents/**/*.pyc
agents/**/*.pyo
agents/**/*.pyd
agents/**/.pytest_cache/

# Scripts — Python
scripts/__pycache__/
scripts/**/__pycache__/
scripts/**/*.pyc

# Scraper — Python
scraper/.venv/
scraper/**/__pycache__/
scraper/**/*.pyc
scraper/.pytest_cache/
scraper/.mypy_cache/
scraper/.ruff_cache/
scraper/src/*.egg-info/
backend/db.sqlite3
backend/staticfiles/
backend/mediafiles/
backend/*.log
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/

# Local MCP config — contains personal access tokens, must not be committed
.mcp.json
