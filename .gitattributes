# Normalize line endings to LF on commit, checkout, and push.
# This ensures consistency across Windows, macOS, and Linux.

* text=auto eol=lf

# Explicitly binary — never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
